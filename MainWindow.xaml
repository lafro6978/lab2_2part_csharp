<Window x:Class="lab2_3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab2_3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <DockPanel Margin="0,5">
                <Button x:Name="BrowseButton" Content="Обзор..." Click="BrowseButton_Click" DockPanel.Dock="Right"/>
                <TextBox x:Name="PathTextBox" Margin="0,0,5,0"/>
            </DockPanel>
            <Button Content="Загрузить данные" Click="LoadDataButton_Click"/>
            <TextBlock x:Name="StatusLabel" Margin="0,10,0,0" Foreground="Green"/>
        </StackPanel>
    </Grid>
</Window>
